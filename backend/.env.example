# Port to run the server on
PORT=5000

# MongoDB Atlas Connection URI
# Example: mongodb+srv://<username>:<password>@cluster.mongodb.net/dbname
MONGO_URI=your_mongodb_atlas_connection_string

# JWT Configuration
# A long random string for signing JWT tokens
JWT_SECRET=your_jwt_secret_key
# JWT expiration time (e.g., 7d, 24h)
JWT_EXPIRE=7d

# CORS Configuration
# Origin for the frontend application (e.g., https://yourapp.vercel.app)
CORS_ORIGIN=http://localhost:5173

# Rate Limiting (Optional - defaults to 15 mins and 1000 requests)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Security (Development or Production)
NODE_ENV=development
HELMET_ENABLED=true

# Socket.IO Configuration
# Usually the same as CORS_ORIGIN
SOCKET_CORS_ORIGIN=http://localhost:5173

# Application Settings
APP_NAME=SESA Educational Platform
APP_VERSION=1.0.0